{
  "name": "ghq-server",
  "version": "1.0.0",
  "description": "GamerHeadQuarter Backend API",
  "main": "index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev":         "nodemon index.js",
    "start":       "node index.js",
    "build":       "npx prisma generate && npx prisma migrate deploy",
    "postinstall": "npx prisma generate",
    "db:push":     "npx prisma db push",
    "db:seed":     "node prisma/seed.js",
    "db:studio":   "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs":       "^2.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.4.5",
    "express":        "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator":  "^7.1.0",
    "helmet":         "^7.1.0",
    "jsonwebtoken":   "^9.0.2",
    "morgan":         "^1.10.0",
    "node-cron":      "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "prisma":  "^5.14.0"
  }
}
